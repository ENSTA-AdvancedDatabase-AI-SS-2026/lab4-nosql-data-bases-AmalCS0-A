// Index 3 : Texte sur diagnostics pour recherche full-text
db.patients.createIndex(
  { "consultations.diagnostic": "text", "consultations.notes": "text" },
  {
    name:     "idx_text_diagnostic_notes",
    default_language: "french"
  }
);

// Index 4 : Analyses par patient (clé de jointure pour $lookup)
db.analyses.createIndex(
  { patient_id: 1, date: -1 },
  { name: "idx_analyses_patient_date" }
);


// ─── 4.2 : Comparer avec explain() ────────────────────────────────────────────

const requeteTest = {
  "adresse.wilaya": "Alger",
  antecedents: "Diabète type 2"
};

// ── AVANT index (simulé en forçant un COLLSCAN) ──────────────────────────────
print("=== AVANT index (hint: $natural force un collscan) ===");
const explainAvant = db.patients
  .find(requeteTest)
  .hint({ $natural: 1 })           // force le balayage complet de la collection
  .explain("executionStats");

print("  Stage            :", explainAvant.executionStats.executionStages.stage);
print("  docsExaminés     :", explainAvant.executionStats.totalDocsExamined);
print("  docsRetournés    :", explainAvant.executionStats.nReturned);
print("  temps (ms)       :", explainAvant.executionStats.executionTimeMillis);

// ── APRÈS index ──────────────────────────────────────────────────────────────
print("\n=== APRÈS index (utilisation de idx_wilaya_antecedents) ===");
const explainApres = db.patients
  .find(requeteTest)
  .hint("idx_wilaya_antecedents")  // force l'utilisation de notre index
  .explain("executionStats");

const stageApres = explainApres.executionStats.executionStages;
print("  Stage            :", stageApres.stage);          // FETCH (ou IXSCAN)
print("  keysExaminées    :", explainApres.executionStats.totalKeysExamined);
print("  docsExaminés     :", explainApres.executionStats.totalDocsExamined);
print("  docsRetournés    :", explainApres.executionStats.nReturned);
print("  temps (ms)       :", explainApres.executionStats.executionTimeMillis);

/*
  Tableau de comparaison attendu :
  ┌──────────────────────┬────────────────┬───────────────┐
  │ Métrique             │ AVANT (COLLSCAN│ APRÈS (IXSCAN)│
  ├──────────────────────┼────────────────┼───────────────┤
  │ Stage                │ COLLSCAN       │ FETCH/IXSCAN  │
  │ totalDocsExamined    │ 20 (= tous)    │ 2-3           │
  │ totalKeysExamined    │ 0              │ 2-3           │
  │ nReturned            │ même valeur    │ même valeur   │
  │ executionTimeMillis  │ plus élevé     │ plus bas      │
  └──────────────────────┴────────────────┴───────────────┘
*/


// ─── 4.4 : Index TTL pour archivage automatique ───────────────────────────────
// Les analyses expirent 5 ans après leur date (5 * 365.25 * 24 * 3600 secondes)
db.analyses.createIndex(
  { date: 1 },
  {
    expireAfterSeconds: 157_788_000,   // ≈ 5 ans
    name: "idx_ttl_analyses_5ans"
  }
);

print("\n✅ Index créés :");
printjson(db.patients.getIndexes().map(i => i.name));
printjson(db.analyses.getIndexes().map(i => i.name));
