// ─── 3.5 : Rapport médecins ───────────────────────────────────────────────────
print("\n=== 3.5 : Top 5 médecins & taux de ré-consultation ===");

const rapportMedecins = db.patients.aggregate([
  // 1. Développer consultations
  { $unwind: "$consultations" },

  // 2. Grouper par médecin :
  //    - compter les consultations totales
  //    - collecter les patient _id uniques via addToSet
  {
    $group: {
      _id: {
        nom:        "$consultations.medecin.nom",
        specialite: "$consultations.medecin.specialite"
      },
      total_consultations: { $sum: 1 },
      patients_uniques:    { $addToSet: "$_id" }
    }
  },

  // 3. Calculer le nombre de patients uniques et le taux de ré-consultation
  {
    $addFields: {
      nb_patients_uniques: { $size: "$patients_uniques" },
      taux_reconsultation: {
        $round: [
          {
            $multiply: [
              {
                $divide: [
                  { $subtract: ["$total_consultations", { $size: "$patients_uniques" }] },
                  { $size: "$patients_uniques" }
                ]
              },
              100
            ]
          },
          1
        ]
      }
    }
  },

  // 4. Tri par total consultations décroissant
  { $sort: { total_consultations: -1 } },

  // 5. Garder les 5 premiers
  { $limit: 5 },

  // 6. Présentation finale
  {
    $project: {
      _id:                  0,
      medecin:              "$_id.nom",
      specialite:           "$_id.specialite",
      total_consultations:  1,
      nb_patients_uniques:  1,
      taux_reconsultation:  1  // en %
    }
  }
]).toArray();

printjson(rapportMedecins);


