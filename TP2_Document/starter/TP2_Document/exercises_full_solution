print("\n=== 3.4 : Profil patients à risque élevé ===");

const patientsRisque = db.patients.aggregate([
  // 1. Filtrer : antécédents Diabète + HTA ET âge > 60
  {
    $match: {
      antecedents: { $all: ["Diabète type 2", "HTA"] },
      dateNaissance: {
        // âge > 60 ans = né avant aujourd'hui - 60 ans
        $lt: new Date(new Date().setFullYear(new Date().getFullYear() - 60))
      }
    }
  },

  // 2. Calculer l'âge et le nombre de consultations
  {
    $addFields: {
      age: {
        $floor: {
          $divide: [
            { $subtract: [new Date(), "$dateNaissance"] },
            1000 * 60 * 60 * 24 * 365.25
          ]
        }
      },
      nb_consultations: { $size: "$consultations" },
      nb_antecedents:   { $size: "$antecedents"   }
    }
  },

  // 3. Projection lisible
  {
    $project: {
      _id:              0,
      nom:              1,
      prenom:           1,
      age:              1,
      wilaya:           "$adresse.wilaya",
      antecedents:      1,
      nb_antecedents:   1,
      nb_consultations: 1,
      groupeSanguin:    1
