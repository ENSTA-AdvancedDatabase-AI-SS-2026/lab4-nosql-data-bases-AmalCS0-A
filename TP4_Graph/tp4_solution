### 1.5 – Relations CONNAIT, SUIT, MAITRISE

#### Relations CONNAIT (graphe connexe garanti)

La stratégie ci-dessous crée trois couches de connexions pour garantir qu'il n'y a aucun nœud isolé :

1. **Chaîne linéaire** sur tous les étudiants → connexité garantie  
2. **Liens par université** → clusters naturels  
3. **Liens par filière** → ponts inter-universités

```cypher
// ── Couche 1 : chaîne linéaire E001→E002→...→E050 ───────────────────────────
// Garantit la connexité globale du graphe
UNWIND [
  ["E001","E002"],["E002","E003"],["E003","E004"],["E004","E005"],
  ["E005","E006"],["E006","E007"],["E007","E008"],["E008","E009"],
  ["E009","E010"],["E010","E011"],["E011","E012"],["E012","E013"],
  ["E013","E014"],["E014","E015"],["E015","E016"],["E016","E017"],
  ["E017","E018"],["E018","E019"],["E019","E020"],["E020","E021"],
  ["E021","E022"],["E022","E023"],["E023","E024"],["E024","E025"],
  ["E025","E026"],["E026","E027"],["E027","E028"],["E028","E029"],
  ["E029","E030"],["E030","E031"],["E031","E032"],["E032","E033"],
  ["E033","E034"],["E034","E035"],["E035","E036"],["E036","E037"],
  ["E037","E038"],["E038","E039"],["E039","E040"],["E040","E041"],
  ["E041","E042"],["E042","E043"],["E043","E044"],["E044","E045"],
  ["E045","E046"],["E046","E047"],["E047","E048"],["E048","E049"],
  ["E049","E050"],["E050","E001"]   -- boucle pour fermer l'anneau
] AS paire
MATCH (a:Etudiant {id: paire[0]}), (b:Etudiant {id: paire[1]})
MERGE (a)-[:CONNAIT]-(b);

// ── Couche 2 : connexions intra-université ───────────────────────────────────
// Chaque étudiant connaît 2–3 camarades de la même université
UNWIND [
  ["E001","E007"],["E001","E017"],["E007","E017"],["E007","E022"],
  ["E017","E022"],["E022","E027"],["E027","E032"],["E032","E037"],
  ["E037","E042"],["E042","E047"],["E002","E008"],["E008","E013"],
  ["E013","E018"],["E018","E023"],["E023","E028"],["E028","E033"],
  ["E033","E038"],["E038","E043"],["E043","E048"],["E003","E009"],-- UMBB/USTO mixte
  ["E004","E014"],["E014","E024"],["E024","E029"],["E029","E034"],
  ["E034","E039"],["E039","E044"],["E044","E049"],["E005","E010"],
  ["E010","E015"],["E015","E020"],["E020","E025"],["E025","E030"],
  ["E030","E035"],["E035","E040"],["E040","E045"],["E006","E011"],
  ["E011","E016"],["E016","E021"],["E021","E026"],["E026","E031"],
  ["E031","E036"],["E036","E041"],["E041","E046"],["E046","E050"]
] AS paire
MATCH (a:Etudiant {id: paire[0]}), (b:Etudiant {id: paire[1]})
MERGE (a)-[:CONNAIT]-(b);

// ── Couche 3 : ponts inter-universités (même filière) ───────────────────────
UNWIND [
  ["E001","E010"],["E001","E014"],["E002","E023"],["E003","E007"],
  ["E005","E035"],["E006","E024"],["E012","E038"],["E019","E035"],
  ["E020","E036"],["E029","E039"],["E032","E042"],["E047","E028"]
] AS paire
MATCH (a:Etudiant {id: paire[0]}), (b:Etudiant {id: paire[1]})
MERGE (a)-[:CONNAIT]-(b);
```

